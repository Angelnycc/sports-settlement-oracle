{
  "compilerOptions": {
    "target": "esnext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "viem":                  ["./node_modules/viem"],
      "viem/*":                ["./node_modules/viem/*"],
      "@chainlink/cre-sdk":    ["./node_modules/@chainlink/cre-sdk"],
      "@chainlink/cre-sdk/*":  ["./node_modules/@chainlink/cre-sdk/*"]
    }
  },
  "include": ["main.ts"]
}
